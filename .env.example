# KnowFlow production-style environment template.
# Copy this file to .env and replace every CHANGE_ME value before deployment.

# Application
KNOWFLOW_APP_HOST_PORT=8080
KNOWFLOW_IMAGE_TAG=latest
REGISTRY_PREFIX=
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
KNOWFLOW_JWT_SECRET=CHANGE_ME_USE_AT_LEAST_32_RANDOM_CHARS

# MySQL
KNOWFLOW_MYSQL_HOST_PORT=3306
KNOWFLOW_DB_HOST=mysql
KNOWFLOW_DB_PORT=3306
KNOWFLOW_DB_NAME=knowflow
KNOWFLOW_DB_USERNAME=knowflow
KNOWFLOW_DB_PASSWORD=CHANGE_ME_DB_PASSWORD
KNOWFLOW_MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

# Redis
KNOWFLOW_REDIS_HOST_PORT=6379
KNOWFLOW_REDIS_HOST=redis
KNOWFLOW_REDIS_PORT=6379
KNOWFLOW_REDIS_DATABASE=0

# RabbitMQ
KNOWFLOW_RABBITMQ_HOST_PORT=5672
KNOWFLOW_RABBITMQ_MANAGEMENT_HOST_PORT=15672
KNOWFLOW_RABBITMQ_HOST=rabbitmq
KNOWFLOW_RABBITMQ_PORT=5672
KNOWFLOW_RABBITMQ_USERNAME=knowflow
KNOWFLOW_RABBITMQ_PASSWORD=CHANGE_ME_RABBITMQ_PASSWORD
KNOWFLOW_PARSE_MESSAGING_MODE=rabbit

# MinIO
KNOWFLOW_MINIO_API_HOST_PORT=9000
KNOWFLOW_MINIO_CONSOLE_HOST_PORT=9001
KNOWFLOW_STORAGE_TYPE=minio
KNOWFLOW_MINIO_ENDPOINT=http://minio:9000
KNOWFLOW_MINIO_ACCESS_KEY=knowflow
KNOWFLOW_MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET
KNOWFLOW_MINIO_BUCKET=knowflow
KNOWFLOW_MINIO_AUTO_CREATE_BUCKET=true

# OpenAI-compatible LLM provider
KNOWFLOW_LLM_OPENAI_ENABLED=false
KNOWFLOW_LLM_OPENAI_BASE_URL=
KNOWFLOW_LLM_OPENAI_API_KEY=CHANGE_ME_OPTIONAL_API_KEY
KNOWFLOW_LLM_OPENAI_CHAT_MODEL=LongCat-Flash-Chat
KNOWFLOW_LLM_OPENAI_FAST_CHAT_MODEL=LongCat-Flash-Chat
KNOWFLOW_LLM_OPENAI_THINKING_CHAT_MODEL=LongCat-Flash-Thinking-2601
KNOWFLOW_LLM_OPENAI_LITE_CHAT_MODEL=LongCat-Flash-Lite
KNOWFLOW_LLM_OPENAI_EXPERIMENTAL_CHAT_MODEL=LongCat-Flash-Chat-2602-Exp
KNOWFLOW_LLM_OPENAI_EMBEDDING_MODEL=
KNOWFLOW_LLM_OPENAI_EMBEDDING_DIMENSIONS=128
KNOWFLOW_LLM_OPENAI_CONNECT_TIMEOUT_MS=5000
KNOWFLOW_LLM_OPENAI_READ_TIMEOUT_MS=30000

# RAG tuning
KNOWFLOW_QA_TOP_K=5
KNOWFLOW_QA_MIN_RECALL_SCORE=0.65
KNOWFLOW_QA_LEXICAL_WEIGHT=0.55
KNOWFLOW_QA_VECTOR_WEIGHT=0.45
KNOWFLOW_QA_LOW_CONFIDENCE_HANDOFF_THRESHOLD=0.50
